{
  "name": "unibrix-dev (Backend + Frontend + Postgres + Mailcatcher + Adminer)",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "backend",
  "workspaceFolder": "/workspaces/app",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "vscode.theme-defaults",
        "johnpapa.vscode-peacock"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "js/ts.tsdk.promptToUseWorkspaceVersion": true,
        "js/ts.tsserver.experimental.enableProjectDiagnostics": true,
        "eslint.workingDirectories": [
          { "directory": "backend", "changeProcessCWD": true },
          { "directory": "frontend", "changeProcessCWD": true }
        ],
        "editor.tabSize": 2,
        "files.exclude": {
          "**/.git": true,
          "**/.svn": true,
          "**/.hg": true,
          "**/.DS_Store": true,
          "**/Thumbs.db": true,
          "**/.idea": true,
          "**/node_modules": true
        },
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/**": true,
          "**/.next/**": true,
          "**/dist/**": true,
          "**/coverage/**": true,
          "**/postgres/**": true
        },
        "js/ts.updateImportsOnFileMove.enabled": "always",
        "editor.multiCursorModifier": "ctrlCmd",
        "git.openRepositoryInParentFolders": "never",
        "git.confirmSync": false,
        "git.enableSmartCommit": true,
        "editor.accessibilitySupport": "off",
        "workbench.startupEditor": "none",
        "git.autofetch": true,
        "security.workspace.trust.untrustedFiles": "open",
        "window.zoomLevel": 1,
        "diffEditor.ignoreTrimWhitespace": false,
        "github.copilot.editor.enableAutoCompletions": true,
        "explorer.confirmPasteNative": false,
        "workbench.iconTheme": "material-icon-theme",
        "files.autoSave": "onFocusChange",
        "editor.minimap.showSlider": "always",
        "files.trimTrailingWhitespace": true,
        "window.confirmBeforeClose": "keyboardOnly",
        "telemetry.telemetryLevel": "off",
        "keyboard.touchbar.enabled": false,
        "explorer.confirmDelete": false,
        "window.density.editorTabHeight": "default",
        "npm.packageManager": "npm",
        "npm.scriptRunner": "npm",
        "editor.fontFamily": "'Fira Code', Monaco, 'Courier New', monospace",
        "editor.fontLigatures": true,
        "editor.lineHeight": 1.5,
        "editor.fontWeight": "350",
        "terminal.integrated.fontFamily": "monospace",
        "terminal.integrated.fontSize": 15,
        "editor.fontSize": 14,
        "workbench.tree.indent": 20,
        "workbench.tree.renderIndentGuides": "onHover",
        "workbench.editor.empty.hint": "hidden",
        "[json]": {
          "editor.defaultFormatter": "vscode.json-language-features"
        },
        "explorer.fileNesting.patterns": {
          "*.ts": "${capture}.js",
          "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
          "*.jsx": "${capture}.js",
          "*.tsx": "${capture}.ts",
          "tsconfig.json": "tsconfig.*.json",
          "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
          "*.sqlite": "${capture}.${extname}-*",
          "*.db": "${capture}.${extname}-*",
          "*.sqlite3": "${capture}.${extname}-*",
          "*.db3": "${capture}.${extname}-*",
          "*.sdb": "${capture}.${extname}-*",
          "*.s3db": "${capture}.${extname}-*"
        },
        "workbench.colorTheme": "Default Light Modern",
        "workbench.preferredDarkColorTheme": "Default Light Modern",
        "window.autoDetectColorScheme": true,
        "cSpell.language": "en,uk",
        "workbench.colorCustomizations": {
          "activityBar.activeBackground": "#65c89b",
          "activityBar.background": "#65c89b",
          "activityBar.foreground": "#15202b",
          "activityBar.inactiveForeground": "#15202b99",
          "activityBarBadge.background": "#945bc4",
          "activityBarBadge.foreground": "#e7e7e7",
          "commandCenter.border": "#15202b99",
          "sash.hoverBorder": "#65c89b",
          "statusBar.background": "#42b883",
          "statusBar.foreground": "#15202b",
          "statusBarItem.hoverBackground": "#359268",
          "statusBarItem.remoteBackground": "#42b883",
          "statusBarItem.remoteForeground": "#15202b",
          "titleBar.activeBackground": "#42b883",
          "titleBar.activeForeground": "#15202b",
          "titleBar.inactiveBackground": "#42b88399",
          "titleBar.inactiveForeground": "#15202b99"
        },
        "peacock.remoteColor": "#42b883"
      }
    }
  },
  "forwardPorts": [4242, 3003, 1080, 8080, 9229],
  "initializeCommand": "touch .devcontainer/.bash_history",
  "postCreateCommand": "node -v && npm -v",
  "mounts": [
    "type=bind,source=${localEnv:HOME}/.codex,target=/home/node/.codex",
    "type=bind,source=${localEnv:HOME}/.gitconfig,target=/home/node/.gitconfig,readonly",
    "type=bind,source=${localWorkspaceFolder}/.devcontainer/.bash_history,target=/home/node/.bash_history"
  ],
  "remoteUser": "node",
  "postStartCommand": "printf '\\n\\n\\n\\033[1;32m[Welcome to unibrix-devcontainer]\\033[0m\\n\\n'",
  "portsAttributes": {
    "3003": { "label": "Frontend", "onAutoForward": "openBrowserOnce" },
    "4242": { "label": "Backend API", "onAutoForward": "notify" },
    "1080": { "label": "Mailcatcher", "onAutoForward": "silent" },
    "8080": { "label": "Adminer", "onAutoForward": "silent" },
    "9229": { "label": "Backend Debugger", "onAutoForward": "silent" }
  }
}
