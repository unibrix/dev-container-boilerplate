# For development with Docker on macOS, we need to enable polling for file watching
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
# Optional: if empty, cloudflared service starts but exits with an error (no tunnel created).
CLOUDFLARED_TOKEN=

# Application
NODE_ENV=development
APP_PORT=4242
APP_URL=https://backend.madlab.pp.ua

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres123
DATABASE_PASSWORD=postgres234
DATABASE_NAME=nestjs
DATABASE_LOGGING=true


# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (optional - for additional token verification)
GOOGLE_CLIENT_ID=294457314790-d1lso9mpq2bml1gskasntovf6kkjb435.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://backend.madlab.pp.ua/api/auth/google/callback

# Mail
MAIL_HOST=mailcatcher
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=Backend App Sender Name
MAIL_FROM_EMAIL=noreply@example.com

# Default locale
DEFAULT_LOCALE=en

# API Configuration
NEXT_PUBLIC_API_URL=https://backend.madlab.pp.ua

# App Configuration
NEXT_PUBLIC_APP_NAME=Client Name
NEXT_PUBLIC_APP_URL=https://frontend.madlab.pp.ua

# Authentication (for backend integration)
NEXT_PUBLIC_AUTH_ENABLED=true

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=294457314790-d1lso9mpq2bml1gskasntovf6kkjb435.apps.googleusercontent.com
